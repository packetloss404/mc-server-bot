# Default provider is gemini (see config.yml llm.provider)
GOOGLE_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here

# ── Dashboard auth ────────────────────────────────────────────────
# When set, all /api/* routes (except /api/auth/*, /api/events/*,
# /api/health, and /api/status) require either an
# `Authorization: Bearer <secret>` header or the `auth` cookie set
# by POSTing the same secret to /api/auth/login. Leave unset to keep
# the dashboard wide open (single-user local-dev case).
# DASHBOARD_AUTH_SECRET=change-me

# When set, /api/events/* (Java plugin → API relay) requires the
# `X-Plugin-Token: <token>` header. Leave unset to keep the legacy
# wide-open behavior.
# PLUGIN_AUTH_TOKEN=plugin-shared-secret
